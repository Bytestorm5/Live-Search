# Response headers for static hosts (Netlify / Cloudflare Pages format).
# For other hosts, configure the equivalent headers (see README §Deployment).
#
# `connect-src` is limited to this origin + the OpenAI API. Audio is streamed to
# wss://api.openai.com for transcription; nothing can be sent anywhere else. The
# huggingface.co/hf.co entries are only needed if you enable optional local
# semantic search (MiniLM) — drop them otherwise.

/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; worker-src 'self' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://api.openai.com wss://api.openai.com https://huggingface.co https://*.huggingface.co https://*.hf.co; object-src 'none'; base-uri 'self'; form-action 'none'; frame-ancestors 'none'
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
