{
  "name": "live-search",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Client-side, privacy-first live speech transcription that drives real-time documentation retrieval.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vite build && playwright test",
    "coverage": "vitest run --coverage",
    "ingest": "tsx scripts/ingest.ts"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.3.3",
    "onnxruntime-web": "^1.20.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^2.1.8",
    "happy-dom": "^15.11.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
