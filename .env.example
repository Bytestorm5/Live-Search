# Model-fetch policy (see README §Privacy modes).
#
# true  (default): fetch model weights from the Hugging Face CDN on first load,
#                  then cache them for offline use. CSP allows only the HF origin.
# false (strict):  self-host all weights under public/models/ and tighten the CSP
#                  connect-src to 'self' for an air-gapped deployment.
VITE_ALLOW_REMOTE_MODELS=true
